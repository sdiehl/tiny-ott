def not
  : Bool -> Bool
  := \b => boolrec (\_ => Bool) false true b
def and
  : Bool -> Bool -> Bool
  := \a => \b => boolrec (\_ => Bool) b false a
def or
  : Bool -> Bool -> Bool
  := \a => \b => boolrec (\_ => Bool) true b a
def xor
  : Bool -> Bool -> Bool
  := \a => \b => boolrec (\_ => Bool) (not b) b a
def not-not-true
  : Eq Bool (not (not true)) true
  := tt
def not-not-false
  : Eq Bool (not (not false)) false
  := tt
def or-id-left
  : Eq Bool (or false true) true
  := tt
def and-zero
  : Eq Bool (and false true) false
  := tt
eval
  = true
  : Bool
eval
  = false
  : Bool
