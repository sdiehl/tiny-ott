def Pair
  : Type -> Type -> Type
  := \A => \B => A * B
def swap
  : (A : Type) -> (B : Type) -> (A * B) -> B * A
  := \A => \B => \p => (snd p, fst p)
def swap-eq
  : (A : Type) -> (B : Type) -> (a : A) -> (b : B) -> Eq (B * A) (swap A B (a, b)) (b, a)
  := \A => \B => \a => \b => (refl, refl)
eval
  = (true, suc (suc (suc zero)))
  : Bool * Nat
eval
  = true
  : Bool
