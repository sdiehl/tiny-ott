-- Type-in-type lets us write polymorphic helpers as plain functions.

def Endo : Type -> Type := \A => A -> A

def apply-endo : (A : Type) -> Endo A -> A -> A
  := \A f x => f x

def twice : (A : Type) -> Endo A -> Endo A
  := \A f x => f (f x)

eval twice Nat (\n => suc n) 3
eval twice Bool (\b => boolrec (\_ => Bool) false true b) true
