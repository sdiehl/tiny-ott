-- Dependent pairs with the universe as the first component.
-- The second component's type depends on the first.

def Pair : Type -> Type -> Type := \A B => A * B

def swap : (A B : Type) -> A * B -> B * A
  := \A B p => (snd p, fst p)

def swap-eq : (A B : Type) -> (a : A) -> (b : B) ->
              Eq (B * A) (swap A B (a, b)) (b, a)
  := \A B a b => refl

eval swap Nat Bool (3, true)
eval fst (swap Nat Bool (3, true))
