def not : Bool -> Bool := \b => boolrec (\_ => Bool) false true b
def and : Bool -> Bool -> Bool := \a b => boolrec (\_ => Bool) b false a
def or  : Bool -> Bool -> Bool := \a b => boolrec (\_ => Bool) true b a
def xor : Bool -> Bool -> Bool := \a b => boolrec (\_ => Bool) (not b) b a

def not-not-true  : Eq Bool (not (not true)) true   := refl
def not-not-false : Eq Bool (not (not false)) false := refl

def or-id-left  : Eq Bool (or false true) true := refl
def and-zero    : Eq Bool (and false true) false := refl

eval xor true false
eval xor true true
