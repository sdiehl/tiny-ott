-- Pujet-Tabareau Section 4: equality is a strict proposition. When a
-- term is checked at a stuck Eq type, elaboration discards the body and
-- emits an irrelevance token (printed as `_`).

-- A stuck Eq type at Nat: the user-written body `p` is erased to _.
def eq-id : (n : Nat) -> (m : Nat) -> Eq Nat n m -> Eq Nat n m
  := \n m p => p

-- Symmetry-like: again the body is at a stuck Eq type and gets erased.
def eq-trivial : (A : Type) -> (x : A) -> (y : A) -> Eq A x y -> Eq A x y
  := \A x y p => p

-- An Eq-Type proof at a stuck pair of types is similarly erased.
def eq-u-id : (A : Type) -> (B : Type) -> Eq Type A B -> Eq Type A B
  := \A B p => p
