def funext :
    (A : Type) -> (B : A -> Type) -> (f g : (x : A) -> B x) ->
    ((x : A) -> Eq (B x) (f x) (g x)) -> Eq ((x : A) -> B x) f g
  := \A B f g h => h

def refl-six : Eq Nat (mul 2 3) 6 := refl

def zero-neq-one : Not (Eq Nat zero (suc zero)) := \p => p

def bool-eq-true : Eq Bool (not (not true)) true := refl
def bool-neq    : Not (Eq Bool true false) := \p => p

eval id Nat (suc zero)
eval add 2 3
eval mul 3 4
